# Tadpole OS Engine Configuration
PORT=8000
BIND_ADDRESS=127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RUST_LOG=server_rs=info,tower_http=debug

# Provider API Keys (Can also be set via UI in Neural Vault)
# OPENAI_API_KEY=your_key_here
# GROQ_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GOOGLE_API_KEY=your_key_here
# INCEPTION_API_KEY=your_key_here
# DEEPSEEK_API_KEY=your_key_here
# REPLICATE_API_KEY=your_key_here

# System Settings
ENGINE_RATE_LIMIT=2000
MAX_CLUSTERS=10
AUTO_APPROVE_SAFE_SKILLS=true
PRIVACY_MODE=false
DEFAULT_AGENT_BUDGET_USD=10.0
TADPOLE_NULL_PROVIDERS=
DISABLE_TELEMETRY=false
NEURAL_TOKEN=
STATIC_DIR=./static
MAX_AGENTS=100
HEARTBEAT_INTERVAL_SECS=30
CLUSTER_ID=local-1
MAX_TASK_LENGTH=1000
DATA_DIR=./data
WORKSPACE_ROOT=..
RESOURCE_ROOT=./resources
MAX_SWARM_DEPTH=5
DATABASE_URL=sqlite://data/tadpole.db
AUDIT_PRIVATE_KEY=
DISCORD_WEBHOOK=

# Models / Vector DB Settings
PIPER_MODEL_PATH=
VAD_MODEL_PATH=
WHISPER_MODEL_PATH=
OLLAMA_HOST=http://localhost:11434
LANCEDB_DEDUPE_THRESHOLD=0.9
LANCEDB_DRIFT_THRESHOLD=0.8
KUBERNETES_SERVICE_HOST=
SME_SYNC_INTERVAL_MINS=30
