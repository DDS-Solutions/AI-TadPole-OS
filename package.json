{
  "name": "tadpole-os",
  "private": true,
  "version": "1.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "engine": "cargo run --manifest-path server-rs/Cargo.toml",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icon": "tauri icon",
    "build:linux:light": "powershell -ExecutionPolicy Bypass -File scripts/build-linux-light.ps1",
    "deploy:legacy-node.tadpole.local": "powershell -ExecutionPolicy Bypass -File scripts/deploy-linuxlite.ps1"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@msgpack/msgpack": "^3.1.3",
    "@types/dagre": "^0.7.53",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12",
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "serialize-javascript": "^7.0.4"
  }
