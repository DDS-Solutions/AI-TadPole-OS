{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI-Tadpole-OS",
  "version": "1.1.12",
  "identifier": "com.tadpole.os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI-Tadpole-OS",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "transparent": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/server-rs"
    ],
    "resources": [
      "../docs/**/*",
      "../src/data/knowledge/**/*",
      "../data/**/*",
      "../.agent/**/*",
      "../.env.schema",
      "../.env.example"
    ]
  }
}
