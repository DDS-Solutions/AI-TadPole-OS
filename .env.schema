# @defaultSensitive=true @defaultRequired=infer
# ---
# Tadpole OS — Environment Schema
# This file documents all environment variables used by the engine.
# It is the single source of truth for configuration, committed to git.
# AI agents can read this schema for context without seeing secret values.
# ---

# -----------------------------------------------------------------------
# Core Engine Configuration
# -----------------------------------------------------------------------

# @required @sensitive @type=string
# Secret token required for all protected engine API endpoints.
# Generate with: openssl rand -hex 32
NEURAL_TOKEN=

# @type=string @default=http://localhost:5173
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=

# @type=string @default=sqlite:data/tadpole.db
# SQLite database connection string.
DATABASE_URL=

# @type=string @default=bunker-1:Swarm Bunker 1:localhost
# Comma-separated list of Swarm Bunker nodes. Format: id:name:hostname
BUNKER_NODES=

# @type=port @default=8000
# HTTP server listen port.
PORT=

# @type=string @default=dist
# Directory for serving static frontend assets.
STATIC_DIR=

# @type=number @default=3
# Interval (seconds) for engine heartbeat broadcasts to connected UIs.
HEARTBEAT_INTERVAL_SECS=

# @type=string @default=data
# @type=number @default=2000
# Maximum number of API requests allowed per minute per IP.
ENGINE_RATE_LIMIT=

# -----------------------------------------------------------------------
# AI Provider API Keys (Sensitive)
# -----------------------------------------------------------------------

# @sensitive @type=string(startsWith=sk-)
# OpenAI API key. Also used as fallback for DeepSeek provider.
OPENAI_API_KEY=

# @sensitive @type=string(startsWith=gsk_)
# High-speed inference key for Groq models (LPU).
GROQ_API_KEY=

# @sensitive @type=string
# Google Cloud / Gemini API key for multimodal reasoning.
GOOGLE_API_KEY=

# @sensitive @type=string(startsWith=sk-ant-)
# Anthropic Claude API key.
ANTHROPIC_API_KEY=

# @sensitive @type=string
# Inception AI API key.
INCEPTION_API_KEY=

# @sensitive @type=string
# DeepSeek API key (falls back to OPENAI_API_KEY if unset).
DEEPSEEK_API_KEY=

# @sensitive @type=url
# Discord webhook URL for agent notifications.
DISCORD_WEBHOOK=

# -----------------------------------------------------------------------
# Audio Engine (Optional)
# -----------------------------------------------------------------------

# @type=string
# Path to Piper TTS model binary.
PIPER_MODEL_PATH=

# @type=string
# Path to Whisper speech-to-text model.
WHISPER_MODEL_PATH=

# @type=string
# Path to Voice Activity Detection model.
VAD_MODEL_PATH=

# -----------------------------------------------------------------------
# Advanced / Debug
# -----------------------------------------------------------------------

# @type=boolean @default=false
# Enable legacy JSON backup for agent registries alongside SQLite.
LEGACY_JSON_BACKUP=

# @type=boolean @default=false
# Force all LLM providers to NullProvider (CI/test mode).
TADPOLE_NULL_PROVIDERS=

# @type=boolean @default=true
# Automatically approve tools tagged as "safe" in their manifest.
AUTO_APPROVE_SAFE_SKILLS=

# @type=boolean @default=false
# If true, blocks all cloud AI providers and enforces local-only operation.
PRIVACY_MODE=

# @type=boolean @default=false
# Allow insecure HTTP connections for local LLM providers.
TADPOLE_ALLOW_LOCAL_HTTP=

# @type=number @default=50
# Maximum number of agents allowed in the registry.
MAX_AGENTS=

# @type=number @default=10
# Maximum number of active clusters.
MAX_CLUSTERS=

# @type=number @default=5
# Maximum recursion depth for agent recruitment/spawning.
MAX_SWARM_DEPTH=

# @type=number @default=32768
# Maximum token length for a single task context.
MAX_TASK_LENGTH=

# @type=number @default=1.0
# Default USD budget allocated to newly recruited agents.
DEFAULT_AGENT_BUDGET_USD=

# @type=number @default=0.85
# Cosine similarity threshold for LanceDB memory deduplication.
LANCEDB_DEDUPE_THRESHOLD=

# @type=number @default=0.6
# Cosine similarity threshold for LanceDB semantic drift detection.
LANCEDB_DRIFT_THRESHOLD=
